miApp/
│
├── database/
│   ├── database.sqlite        # Base de datos SQLite
│   └── schema.sql             # Estructura inicial de tablas
│
├── src/
│   ├── config/                # Conexión y configuración de SQLite
│   │
│   ├── controllers/           # Lógica que maneja req/res
│   │
│   ├── middlewares/           # Middlewares globales (errores)
│   │
│   ├── services/              # Lógica de negocio
│   │
│   ├── models/                # Acceso y consultas a la base de datos
│   │
│   ├── routes/
│   │   ├── contacts.routes.ts # Rutas de contactos
│   │   └── tasks.routes.ts    # Rutas de tareas
│   │
│   ├── types/                 # Tipos e interfaces TypeScript
│   │
│   ├── app.ts                 # Configuración principal de Express
│   └── server.ts              # Inicio del servidor
│
├── package.json               # Dependencias y scripts
├── tsconfig.json              # Configuración TypeScript
└── nodemon.json               # Configuración de recarga automática

